<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/linkod_white"
    android:gravity="center">

    <!-- Container for centered content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingLeft="24dp"
        android:paddingRight="24dp">

        <!-- Information Icon -->
        <ImageView
            android:id="@+id/infoIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="24dp"
            android:contentDescription="@string/announcement_icon_description"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_dialog_info" />

        <!-- Title -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/barangay_announcement"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/linkod_green_primary"
            android:textAlignment="center"
            android:layout_marginBottom="16dp" />

        <!-- Body Text -->
        <TextView
            android:id="@+id/bodyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/new_announcement_message"
            android:textSize="16sp"
            android:textColor="@color/linkod_gray_text"
            android:textAlignment="center"
            android:layout_marginBottom="32dp"
            android:lineSpacingMultiplier="1.5" />

    </LinearLayout>

    <!-- Button Container at Bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="24dp"
        android:background="@color/linkod_gray_light">

        <!-- View Button -->
        <Button
            android:id="@+id/viewButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/view_button"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/linkod_white"
            android:background="@drawable/button_green_background"
            android:layout_marginEnd="12dp" />

        <!-- Dismiss Button -->
        <Button
            android:id="@+id/dismissButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/dismiss_button"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/linkod_green_primary"
            android:background="@drawable/button_outline_background" />

    </LinearLayout>

</LinearLayout>
