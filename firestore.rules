rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========= Helper functions =========

    function isSignedIn() {
      return request.auth != null;
    }

    // Safe accessor for current user's Firestore doc
    // Note: Only call this after checking hasUserDoc() to avoid errors
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserDoc() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    // Safe role getter - returns null if doc doesn't exist or role field is missing
    function getUserRole() {
      return hasUserDoc() ? userDoc().data.role : null;
    }

    // Role helpers. Only two roles: super_admin and admin. Positions (e.g. official, staff) are labels only.
    function role() {
      return getUserRole();
    }

    // Only Super Admin has full access (Approvals, User Management, adminSettings, etc.)
    function isSuperAdmin() {
      return hasUserDoc() &&
        getUserRole() == 'super_admin';
    }

    // Any admin-panel account (can log into Windows app). Only two roles: super_admin and admin.
    function isAdminPanelUser() {
      return hasUserDoc() &&
        getUserRole() in ['super_admin', 'admin'];
    }
	
  	// ========= adminSettings =========
    // Stores panel-wide flags such as auto-approve settings.
    match /adminSettings/{docId} {
      // Only Super Admin can read/write these settings.
      allow read, write: if isSuperAdmin();
    }

    // ========= publicSettings =========
    // Auto-approve flags for residents (products/tasks). Read by mobile app so
    // new listings can be created as Approved when enabled. Write by Super Admin only.
    match /publicSettings/{docId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // ========= users collection =========

    match /users/{userId} {
      // SUPER ADMIN: full access to all profiles
      allow read, write: if isSuperAdmin();

      // Owner: can read and update own profile (includes declined users re-applying: accountStatus, proofOfResidenceUrl, etc.)
      allow read, update: if isSignedIn() && request.auth.uid == userId;

      // Only Super Admin can read other users (User Management). Admin is limited to Dashboard and Announcements.
      allow read: if isSuperAdmin();

      // Any signed-in user can read basic profile info of other users
      // (for marketplace message avatars, resident profile dialogs, etc.)
      allow get: if isSignedIn();

      // Create user docs: only Super Admin
      allow create: if isSuperAdmin();

      // Allow other signed-in users to bump unreadNotificationCount for this user
      // (e.g. when creating a like/comment notification). Only this single field
      // may change in this rule.
      allow update: if isSignedIn()
        && request.auth.uid != userId
        && request.resource.data.diff(resource.data).changedKeys()
             .hasOnly(['unreadNotificationCount']);

      // Devices subcollection: FCM tokens
      match /devices/{deviceId} {
        // Owner can manage own devices
        allow read, write: if isSignedIn() && request.auth.uid == userId;

        // SUPER ADMIN may need to inspect devices (optional)
        allow read: if isSuperAdmin();
      }
    }

    // ========= awaitingApproval =========
    // Sign-up / verification requests (mobile creates without Auth; Super Admin approves later)

    match /awaitingApproval/{docId} {
      // Only Super Admin can list/read all. Applicant can read their own doc.
      allow read: if isSuperAdmin()
        || (isSignedIn() && resource.data.requestedByUid == request.auth.uid);

      // Mobile create-account does NOT sign in first — allow unauthenticated create so registration works
      allow create: if true;

      // Update: only Super Admin or the applicant (e.g. add fcmTokens, resubmit)
      allow update: if isSuperAdmin()
        || (isSignedIn() && resource.data.requestedByUid == request.auth.uid);

      // Delete: Super Admin (approve/decline flow) or applicant (original email-style mapping)
      allow delete: if isSuperAdmin()
        || (isSignedIn()
          && request.auth.token.email == (resource.data.phoneNumber + '@linkod.com'));
    }

    // ========= announcements =========

    match /announcements/{docId} {
      // Any signed-in user can read announcements
      allow read: if isSignedIn();

      // Create: Super Admin and Admin can create (Admin submissions need approval; app logic)
      allow create: if isAdminPanelUser();

      // Update:
      // - SUPER ADMIN can fully update (approve/decline, edit)
      allow update: if isSuperAdmin();

      // Special case: legacy behavior where non-admins update only viewCount/updatedAt.
      // Keep this for backward compatibility, but restrict to signed-in non-admin-panel users.
      allow update: if isSignedIn()
        && !isAdminPanelUser()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['viewCount', 'updatedAt']);

      // No client-side delete except SUPER ADMIN
      allow delete: if isSuperAdmin();

      // Subcollection: views (reader list) – new behavior
      match /views/{viewId} {
        // Any signed-in user can mark as read
        allow create: if isSignedIn();

        // Signed-in users can read the reader list for resident-side viewers UI.
        // Super Admin keeps full access by virtue of signed-in access.
        allow read: if isSignedIn();

        // No client updates/deletes
        allow update, delete: if false;
      }
    }

    // ========= announcementDrafts =========
    // Drafts in admin app.

    match /announcementDrafts/{docId} {
      // Super Admin and Admin can read/write drafts (Admin limited to own drafts by app)
      allow read, write: if isAdminPanelUser();
    }

    // ========= adminActivities =========
    // Recent activities feed in admin dashboard

    match /adminActivities/{docId} {
      allow read, write: if isAdminPanelUser();
    }

    // ========= barangayCategories =========
    // Barangay information categories (created by admin)

    match /barangayCategories/{docId} {
      // Any signed-in user can read categories (for mobile app)
      allow read: if isSignedIn();
      
      // Only admin panel users can create/update/delete categories
      allow create, update, delete: if isAdminPanelUser();
    }

    // ========= barangayPostings =========
    // Postings within barangay information categories

    match /barangayPostings/{docId} {
      // Any signed-in user can read postings (for mobile app)
      allow read: if isSignedIn();
      
      // Only admin panel users can create/update/delete postings
      allow create, update, delete: if isAdminPanelUser();
    }

    // ========= barangaySettings =========
    // Barangay branding settings (logo and cover image URLs)

    match /barangaySettings/{docId} {
      // Any signed-in user can read settings (for mobile app bulletin board)
      allow read: if isSignedIn();
      
      // Only admin panel users can update branding settings
      allow create, update, delete: if isAdminPanelUser();
    }

    // ========= posts =========
    // General posts from mobile app

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();

      // Owner or any admin-panel user can update/delete
      allow update, delete: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdminPanelUser());

      match /likes/{likeId} {
        allow read, write: if isSignedIn();
      }

      match /comments/{commentId} {
        allow read, write: if isSignedIn();
      }
      
      match /comment_read/{userId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // ========= products (marketplace) =========

    match /products/{productId} {
      allow read: if isSignedIn();

      // Mobile users create listings (status: Pending)
      allow create: if isSignedIn();

      // SUPER ADMIN or seller can update/delete
      allow update, delete: if isSignedIn()
        && (isSuperAdmin() || resource.data.sellerId == request.auth.uid);

      // Legacy special case: messagesCount updates by non-seller, non-admin
      // for chat/thread counters.
      allow update: if isSignedIn()
        && !isAdminPanelUser()
        && resource.data.sellerId != request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['messagesCount', 'viewCount', 'updatedAt']);

      match /views/{viewId} {
        // Any signed-in user can record and read product viewers.
        allow create, read: if isSignedIn();
        allow update, delete: if false;
      }

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        // Only message sender can update/delete their own message
        allow update, delete: if isSignedIn()
          && resource.data.senderId == request.auth.uid;
      }

      match /message_read/{userId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // ========= tasks (errands) =========

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();

      // SUPER ADMIN: full update/delete
      allow update, delete: if isSuperAdmin();

      // Requester or assignedTo can update, but NOT change approvalStatus
      allow update: if isSignedIn()
        && (resource.data.requesterId == request.auth.uid
            || resource.data.assignedTo == request.auth.uid)
        && request.resource.data.approvalStatus == resource.data.approvalStatus;

      // Volunteer flow: any signed-in user may update only volunteersCount,
      // pendingVolunteersCount and updatedAt (increment on volunteer, decrement on cancel/reject)
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['volunteersCount', 'pendingVolunteersCount', 'unreadVolunteersCount', 'updatedAt']);

      // View tracking flow: any signed-in user may update only viewCount and updatedAt.
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['viewCount', 'updatedAt']);

      // Participants can delete their own tasks? (Keep legacy behavior)
      allow delete: if isSignedIn()
        && (resource.data.requesterId == request.auth.uid
            || resource.data.assignedTo == request.auth.uid);

      match /volunteers/{volunteerDocId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn()
          && get(/databases/$(database)/documents/tasks/$(taskId)).data.requesterId == request.auth.uid;
        // Volunteer can cancel their own pending request
        allow delete: if isSignedIn()
          && resource.data.volunteerId == request.auth.uid
          && resource.data.status == 'pending';
        // Task owner can remove any volunteer (pending or accepted)
        allow delete: if isSignedIn()
          && get(/databases/$(database)/documents/tasks/$(taskId)).data.requesterId == request.auth.uid;
      }

      match /chat_messages/{messageId} {
        allow read, write: if isSignedIn()
          && (get(/databases/$(database)/documents/tasks/$(taskId)).data.requesterId == request.auth.uid
              || get(/databases/$(database)/documents/tasks/$(taskId)).data.assignedTo == request.auth.uid);
      }

      match /chat_read/{userId} {
        allow read, write: if isSignedIn()
          && request.auth.uid == userId
          && (get(/databases/$(database)/documents/tasks/$(taskId)).data.requesterId == request.auth.uid
              || get(/databases/$(database)/documents/tasks/$(taskId)).data.assignedTo == request.auth.uid);
      }

      match /views/{viewId} {
        // Any signed-in user can record and read task viewers.
        allow create, read: if isSignedIn();
        allow update, delete: if false;
      }
    }

    // ========= notifications =========
    // Schema (typical):
    // {
    //   userId: string,          // receiver
    //   senderId: string,        // actor (creator of the notification)
    //   type: string,            // e.g. "comment" | "like" | "message" | "task"
    //   postId: string?,
    //   productId: string?,
    //   taskId: string?,
    //   commentId: string?,
    //   messageId: string?,
    //   announcementId: string?,
    //   message: string?,
    //   isRead: bool,
    //   createdAt: timestamp
    // }

    match /notifications/{notificationId} {
      // Allow list queries when user filters by their own userId
      allow list: if isSignedIn()
        && request.query.limit <= 100
        && (
          // Query filters by userId == request.auth.uid
          (request.query.filters[0].field == 'userId'
            && request.query.filters[0].op == '=='
            && request.query.filters[0].value == request.auth.uid)
          || (request.query.filters.size() > 1
            && request.query.filters[0].field == 'userId'
            && request.query.filters[0].op == '=='
            && request.query.filters[0].value == request.auth.uid)
        );

      // Owner can read/update/delete their own notifications
      allow read, update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      // Users can create notifications for themselves
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;

      // Mobile app: allow users to create notifications for other users when
      // they are the sender and the receiver is the owner/requester/seller
      // of the related resource (post/product/task). This supports likes,
      // comments, marketplace messages, and task events without Cloud Functions.
      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.userId is string
        && (
          // Feed posts: like — receiver is post.userId
          (
            request.resource.data.postId is string
            && request.resource.data.type == 'like'
            && get(/databases/$(database)/documents/posts/$(request.resource.data.postId)).data.userId
                 == request.resource.data.userId
          )
          ||
          // Feed posts: comment — receiver is post.userId
          (
            request.resource.data.postId is string
            && request.resource.data.type == 'comment'
            && get(/databases/$(database)/documents/posts/$(request.resource.data.postId)).data.userId
                 == request.resource.data.userId
          )
          ||
          // Feed posts: reply — receiver is post.userId
          (
            request.resource.data.postId is string
            && request.resource.data.type == 'reply'
            && get(/databases/$(database)/documents/posts/$(request.resource.data.postId)).data.userId
                 == request.resource.data.userId
          )
          ||
          // Marketplace: product_message — receiver is products.sellerId
          (
            request.resource.data.productId is string
            && request.resource.data.type == 'product_message'
            && get(/databases/$(database)/documents/products/$(request.resource.data.productId)).data.sellerId
                 == request.resource.data.userId
          )
          ||
          // Tasks: volunteer application — receiver is the task requester (owner)
          (
            request.resource.data.taskId is string
            && request.resource.data.type == 'task_volunteer'
            && get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.requesterId
                 == request.resource.data.userId
          )
          ||
          // Tasks chat: allow notifying the other participant (requester <-> assigned volunteer)
          (
            request.resource.data.taskId is string
            && request.resource.data.type == 'task_chat_message'
            && (
              get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.requesterId
                == request.auth.uid
              || get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.assignedTo
                == request.auth.uid
            )
            && request.resource.data.userId != request.auth.uid
            && (
              request.resource.data.userId
                == get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.requesterId
              || (
                get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.assignedTo is string
                && request.resource.data.userId
                  == get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.assignedTo
              )
            )
          )
          ||
          // Tasks: volunteer accepted — receiver is the assigned volunteer
          (
            request.resource.data.taskId is string
            && request.resource.data.type == 'volunteer_accepted'
            && get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.requesterId
                 == request.auth.uid
            && get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.assignedTo
                 == request.resource.data.userId
          )
        );

      // Only Super Admin can create notifications for any user (e.g. account approval)
      allow create: if isSuperAdmin();
    }

    // ========= pushSendLogs =========
    // Logs of push notification sends (backend writes, admin reads)

    match /pushSendLogs/{logId} {
      // Admin panel users can read logs
      allow read: if isAdminPanelUser();
      
      // Backend service account writes logs (via Admin SDK, bypasses rules)
      allow write: if false;  // Only via Admin SDK
    }

    // ========= user_task_interactions =========
    // Tracks which tasks a user has interacted with (for Activity Log)
    // Document ID format: {userId}_{taskId}

    match /user_task_interactions/{interactionId} {
      // Helper: check if document belongs to current user (by ID prefix or field)
      function isOwner() {
        return (resource.data != null && resource.data.userId == request.auth.uid)
          || interactionId.matches(request.auth.uid + "_.*");
      }
      function willBeOwner() {
        return request.resource.data.userId == request.auth.uid
          || interactionId.matches(request.auth.uid + "_.*");
      }

      // Users can read their own interactions
      allow read: if isSignedIn() && isOwner();

      // Users can create interactions for themselves
      allow create: if isSignedIn() && willBeOwner();

      // Users can update their own interactions (e.g., unreadReplyCount)
      allow update: if isSignedIn() && isOwner();

      // Users can delete their own interactions
      allow delete: if isSignedIn() && isOwner();
    }

    // ========= user_product_interactions =========
    // Tracks which products a user has interacted with (for Activity Log)
    // Document ID format: {userId}_{productId}

    match /user_product_interactions/{interactionId} {
      // Helper: check if document belongs to current user (by ID prefix or field)
      function isOwner() {
        return (resource.data != null && resource.data.userId == request.auth.uid)
          || interactionId.matches(request.auth.uid + "_.*");
      }
      function willBeOwner() {
        return request.resource.data.userId == request.auth.uid
          || interactionId.matches(request.auth.uid + "_.*");
      }

      // Users can read their own interactions
      allow read: if isSignedIn() && isOwner();

      // Users can create interactions for themselves
      allow create: if isSignedIn() && willBeOwner();

      // Users can update their own interactions (e.g., unreadReplyCount)
      allow update: if isSignedIn() && isOwner();

      // Users can delete their own interactions
      allow delete: if isSignedIn() && isOwner();
    }

    // ========= userAnnouncementReads =========
    // Per-user read tracking (separate from announcements/{id}/views)

    match /userAnnouncementReads/{readId} {
      allow read: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
    }

    // ==================== OTP & Phone Verification ====================

    /// Pending OTP Records
    /// - Only accessible via Cloud Functions (service account)
    /// - Stores temporary OTP codes with 2-minute expiration
    /// - Clients cannot directly read/write (security via rules)
    match /pendingOtps/{docId} {
      allow read, write: if false;
      // Cloud Functions have service account access
    }

    /// Verified Phone Numbers
    /// - Authenticated users can read (check if phone is verified)
    /// - Only writable via Cloud Functions (after OTP verification)
    /// - Stores phone number verification records
    match /verifiedPhones/{phoneNumber} {
      allow read: if isSignedIn();
      allow write: if false;
      // Only writable via Cloud Functions
    }
  }
}
